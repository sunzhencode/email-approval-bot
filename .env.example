# Feishu IMAP
IMAP_HOST=imap.larksuite.com
IMAP_PORT=993
IMAP_USER=your@feishu.cn
IMAP_PASSWORD=your_app_password

# Email filtering
TARGET_EMAIL=your-group@example.com
POLL_INTERVAL_SECONDS=60

# Approval: comma-separated whitelist of email addresses allowed to approve
APPROVED_SENDERS=alice@example.com,bob@example.com

# Approval: case-insensitive keywords (any match counts as approval)
APPROVAL_KEYWORDS=approve,approved,ok,同意,lgtm,好的,yes,+1

# Skip keywords: if YOU reply with one of these, the request is marked as manually handled
SKIP_KEYWORDS=done,已完成,已执行,手动执行,manual

# How many days back to search on first startup (default: 3)
LOOKBACK_DAYS=3

# GoCD
GOCD_BASE_URL=https://gocd.example.com
GOCD_TOKEN=your_gocd_api_token
# Pipeline → execute stage mapping (pipeline_name:stage_name, comma-separated)
GOCD_STAGE_MAP=ES-DATA-UPDATE-PROD:es-data-update,POD-CURL-PROD:pod-curl
# Fallback if pipeline not in map (leave empty to skip unknown pipelines)
GOCD_DEFAULT_STAGE=
# Set to true to log GoCD API calls without actually firing them
GOCD_DRY_RUN=false
# Minutes to wait for a triggered stage to complete before marking as timeout (default: 60)
GOCD_STATUS_TIMEOUT_MINUTES=60

# State DB
DB_PATH=./state.db

# SMTP reply (optional — leave SMTP_HOST empty to disable Done replies)
# Reuses IMAP_USER / IMAP_PASSWORD credentials
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465

# Feishu bot notification (optional, leave empty to disable)
# Create a bot in your Feishu group: 群设置 → 群机器人 → 添加机器人 → 自定义机器人 → copy webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here
